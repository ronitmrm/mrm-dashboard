# Convex cloud deployment selected by local Convex CLI commands.
# Leave blank when using the local self-hosted backend.
# Example: dev:your-deployment-name
CONVEX_DEPLOYMENT=

# Local self-hosted Convex CLI connection.
# Start with `pnpm convex:local:up`, then generate the admin key with
# `pnpm convex:local:admin-key`.
# Example: http://127.0.0.1:3210
CONVEX_SELF_HOSTED_URL=
CONVEX_SELF_HOSTED_ADMIN_KEY=

# Convex URL used by the Next.js app and browser client.
# Cloud example: https://your-deployment.convex.cloud
# Local self-hosted example: http://127.0.0.1:3210
NEXT_PUBLIC_CONVEX_URL=

# Convex site URL used by Convex Auth provider configuration.
# Cloud example: https://your-deployment.convex.site
# Local self-hosted example: http://127.0.0.1:3211
CONVEX_SITE_URL=

# Optional public site URL for client-side links or deployment metadata.
# Keep this aligned with CONVEX_SITE_URL if your deployment needs it.
NEXT_PUBLIC_CONVEX_SITE_URL=
